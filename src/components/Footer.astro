			</svg>
		</a>
		<a href="/rss.xml" aria-label="RSS feed" title="RSS feed">
			<svg
				xmlns="http://www.w3.org/2000/svg"
				viewBox="0 0 24 24"
				width="20"
				height="20"
				fill="currentColor"
				aria-hidden="true"
			>
				<path
					d="M4 11a9 9 0 0 1 9 9h2.5A11.5 11.5 0 0 0 4 8.5V11Zm0 4a5 5 0 0 1 5 5h2.5A7.5 7.5 0 0 0 4 12.5V15Zm1.5 5a1.5 1.5 0 1 0 0-3 1.5 1.5 0 0 0 0 3Z"
				></path>
			</svg>
		</a>
	</div>
</footer>
<style>
	footer {
		padding: 25px;
		text-align: center;
		font-size: 0.8rem;
	}

	.footer-icons {
		display: inline-flex;
		gap: 12px;
		margin-top: 8px;
	}

	.footer-icons a {
		display: inline-flex;
		color: inherit;
		opacity: 0.7;
		transition: opacity 0.2s ease;
	}

	.footer-icons a:hover {
		opacity: 1;
	}
</style>
